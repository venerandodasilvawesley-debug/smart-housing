from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session
from app.database import SessionLocal
from app.models import Colaborador

router = APIRouter(prefix="/colaboradores", tags=["Colaboradores"])

# Dependência para obter sessão do banco
def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

# Listar todos
@router.get("/")
def listar_colaboradores(db: Session = Depends(get_db)):
    return db.query(Colaborador).all()

# Buscar por ID
@router.get("/{colaborador_id}")
def buscar_colaborador(colaborador_id: int, db: Session = Depends(get_db)):
    colaborador = db.query(Colaborador).filter(Colaborador.id == colaborador_id).first()
    if not colaborador:
        raise HTTPException(status_code=404, detail="Colaborador não encontrado")
    return colaborador

# Criar novo
@router.post("/")
def criar_colaborador(nome: str, documento: str, empresa: str = None, setor: str = None, db: Session = Depends(get_db)):
    novo = Colaborador(nome=nome, documento=documento, empresa=empresa, setor=setor)
    db.add(novo)
    db.commit()
    db.refresh(novo)
    return novo

# Atualizar
@router.put("/{colaborador_id}")
def atualizar_colaborador(colaborador_id: int, nome: str = None, empresa: str = None, setor: str = None, ativo: bool = None, db: Session = Depends(get_db)):
    colaborador = db.query(Colaborador).filter(Colaborador.id == colaborador_id).first()
    if not colaborador:
        raise HTTPException(status_code=404, detail="Colaborador não encontrado")
    if nome: colaborador.nome = nome
    if empresa: colaborador.empresa = empresa
    if setor: colaborador.setor = setor
    if ativo is not None: colaborador.ativo = ativo
    db.commit()
    db.refresh(colaborador)
    return colaborador

# Deletar
@router.delete("/{colaborador_id}")
def deletar_colaborador(colaborador_id: int, db: Session = Depends(get_db)):
    colaborador = db.query(Colaborador).filter(Colaborador.id == colaborador_id).first()
    if not colaborador:
        raise HTTPException(status_code=404, detail="Colaborador não encontrado")
    db.delete(colaborador)
    db.commit()
    return {"msg": "Colaborador deletado com sucesso"}
